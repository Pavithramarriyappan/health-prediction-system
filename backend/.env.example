PORT=5000
MONGO_URI=your_mongo_connection_string
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.0

# JWT Authentication
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=7d

# Email Configuration (Optional - for Gmail SMTP)
# How to set up: 
# 1. Enable 2-Factor Authentication on your Google Account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Create an "App Password" for Mail
# 4. Copy the 16-character password and paste it below (without spaces)
# 5. Use your Gmail address for EMAIL_USER
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password

# Twilio WhatsApp Integration (optional)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=+1234567890
